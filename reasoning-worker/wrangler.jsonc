{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ai-tutor-reasoning",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  },
  // Model specifiers are provider/model (e.g. openai/gpt-5.5, openrouter/openai/gpt-5.5).
  // These are FALLBACKS only: in production Worker A ships each stage's model from the
  // DB-backed provider_settings table (editable from /settings) as a per-call `payload.model`
  // override, and the workflows forward it into `session.prompt({ model })`. REASONING_MODEL
  // is the shared fallback for gate-check/verifier/extract-question; TUTOR_MODEL overrides
  // only tutor-turn and falls back to REASONING_MODEL. They let Worker B run standalone (no
  // payload model) and serve as the floor if Worker A ever omits the field. See
  // docs/adr/0001-flue-reasoning-worker.md.
  "vars": {
    "REASONING_MODEL": "openai/gpt-5.5",
    "TUTOR_MODEL": "openrouter/nvidia/nemotron-3-ultra-550b-a55b"
  },
  "secrets": {
    "required": ["OPENAI_API_KEY", "OPENROUTER_API_KEY"]
  },
  "migrations": [
    {
      "tag": "v1-flue-reasoning",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueExtractQuestionWorkflow",
        "FlueGateCheckWorkflow",
        "FlueVerifierWorkflow",
        "FlueTutorTurnWorkflow"
      ]
    }
  ]
}
