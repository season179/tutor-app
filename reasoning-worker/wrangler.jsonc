{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ai-tutor-reasoning",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": ["nodejs_compat"],
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    }
  },
  // Model specifiers are provider/model (e.g. openai/gpt-5.5, openrouter/openai/gpt-5.5).
  // REASONING_MODEL is the shared default for gate-check/verifier/extract-question; TUTOR_MODEL
  // overrides ONLY the tutor-turn stage (the conversational LLM between STT and TTS) and falls
  // back to REASONING_MODEL when unset. Swapping either is a one-var change here plus the matching
  // *_API_KEY secret — no domain code in Worker A changes. See docs/adr/0001-flue-reasoning-worker.md.
  "vars": {
    "REASONING_MODEL": "openai/gpt-5.5",
    "TUTOR_MODEL": "openrouter/nvidia/nemotron-3-ultra-550b-a55b"
  },
  "secrets": {
    "required": ["OPENAI_API_KEY", "OPENROUTER_API_KEY"]
  },
  "migrations": [
    {
      "tag": "v1-flue-reasoning",
      "new_sqlite_classes": [
        "FlueRegistry",
        "FlueExtractQuestionWorkflow",
        "FlueGateCheckWorkflow",
        "FlueVerifierWorkflow",
        "FlueTutorTurnWorkflow"
      ]
    }
  ]
}
