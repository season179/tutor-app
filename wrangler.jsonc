{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ai-tutor",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": ["nodejs_compat"],
  // Static assets are wired by @cloudflare/vite-plugin at build time (it emits the
  // client bundle and configures asset serving). The asset router serves matching
  // static assets first; the worker runs for everything else — SSR of `/` and all
  // /api/* routes.
  "r2_buckets": [
    {
      "binding": "PROBLEM_IMAGES",
      "bucket_name": "ai-tutor-problem-images",
      "remote": true
    }
  ],
  "vars": {
    "VOICE_BACKEND": "openai-voice-pipeline",
    "OPENAI_TUTOR_MODEL": "gpt-5.5",
    "OPENAI_GATE_CHECKER_MODEL": "gpt-5.5",
    "OPENAI_VERIFIER_MODEL": "gpt-5.5",
    "OPENAI_TRANSCRIBE_MODEL": "gpt-4o-transcribe",
    "OPENAI_TTS_MODEL": "gpt-4o-mini-tts",
    "OPENAI_TTS_VOICE": "marin",
    "OPENAI_REALTIME_MODEL": "gpt-realtime-2",
    "OPENAI_REALTIME_VOICE": "marin",
    "OPENAI_SAFETY_IDENTIFIER": "cloudflare-ai-tutor-user",
    "OPENAI_VISION_MODEL": "gpt-5.5",
    "R2_BUCKET_NAME": "ai-tutor-problem-images",
    "BETTER_AUTH_URL": "https://ai-tutor.dev"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ai-tutor-sessions",
      "database_id": "de91aacb-27a7-4b10-a117-8f300664695d",
      "migrations_dir": "migrations"
    }
  ],
  "durable_objects": {
    "bindings": [{ "name": "SESSION_RUNTIME", "class_name": "SessionRuntimeDO" }]
  },
  "migrations": [{ "tag": "v1-session-runtime", "new_classes": ["SessionRuntimeDO"] }],
  "secrets": {
    "required": [
      "OPENAI_API_KEY",
      "BETTER_AUTH_SECRET",
      "GOOGLE_CLIENT_ID",
      "GOOGLE_CLIENT_SECRET",
      "R2_ACCESS_KEY_ID",
      "R2_SECRET_ACCESS_KEY",
      "R2_ACCOUNT_ID"
    ]
  },
  "ratelimits": [
    {
      "name": "REALTIME_TOKEN_RATE_LIMITER",
      "namespace_id": "2026061401",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    }
  }
}
