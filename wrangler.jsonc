{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "ai-tutor",
  "main": "src/worker.ts",
  "compatibility_date": "2026-06-14",
  "compatibility_flags": ["nodejs_compat"],
  // Static assets are wired by @cloudflare/vite-plugin at build time (it emits the
  // client bundle and configures asset serving). The asset router serves matching
  // static assets first; the worker runs for everything else — SSR of `/` and all
  // /api/* routes.
  "r2_buckets": [
    {
      "binding": "PROBLEM_IMAGES",
      "bucket_name": "ai-tutor-problem-images",
      "remote": true
    }
  ],
  "vars": {
    // Provider/model selection moved to the DB-backed provider_settings table (editable
    // from /settings); only non-model config stays here. The OPENAI_*_MODEL /
    // OPENROUTER_*_MODEL vars that used to hold the model strings were removed with that
    // migration — the defaults live in the migration seed (0011_provider_settings.sql).
    "R2_BUCKET_NAME": "ai-tutor-problem-images",
    "BETTER_AUTH_URL": "https://ai-tutor.dev"
  },
  "d1_databases": [
    {
      "binding": "DB",
      "database_name": "ai-tutor-sessions",
      "database_id": "de91aacb-27a7-4b10-a117-8f300664695d",
      "migrations_dir": "migrations"
    }
  ],
  "durable_objects": {
    "bindings": [{ "name": "SESSION_RUNTIME", "class_name": "SessionRuntimeDO" }]
  },
  "migrations": [{ "tag": "v1-session-runtime", "new_classes": ["SessionRuntimeDO"] }],
  // Worker B (Flue) holds the reasoning stages. The service binding is visible inside
  // SessionRuntimeDO via this.env, so per-turn reasoning calls (which run inside the DO)
  // can reach it. Local dev needs both workers running — see AGENTS.md "Two-worker dev".
  "services": [
    { "binding": "REASONING", "service": "ai-tutor-reasoning" }
  ],
  "secrets": {
    "required": [
      "OPENROUTER_API_KEY",
      "BETTER_AUTH_SECRET",
      "GOOGLE_CLIENT_ID",
      "GOOGLE_CLIENT_SECRET",
      "R2_ACCESS_KEY_ID",
      "R2_SECRET_ACCESS_KEY",
      "R2_ACCOUNT_ID"
    ]
  },
  "ratelimits": [
    {
      "name": "VOICE_RATE_LIMITER",
      "namespace_id": "2026061401",
      "simple": {
        "limit": 10,
        "period": 60
      }
    }
  ],
  "observability": {
    "enabled": true,
    "logs": {
      "head_sampling_rate": 1
    },
    "traces": {
      "enabled": true,
      "head_sampling_rate": 1
    }
  }
}
