OPENAI_API_KEY=your-openai-api-key
VOICE_BACKEND=openai-realtime
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
# Local label. The server hashes this before sending OpenAI-Safety-Identifier.
OPENAI_SAFETY_IDENTIFIER=local-ai-tutor-user
# Cloudflare Access (required in production Worker; optional for local Node dev with bypass)
TEAM_DOMAIN=https://your-team.cloudflareaccess.com
POLICY_AUD=your-access-application-aud-tag
# Node dev only: used when no Cf-Access-Jwt-Assertion header is present
ACCESS_DEV_IDENTITY={"sub":"dev-user","email":"dev@example.com"}
