{
  "name": "ai-tutor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm typecheck:tsc && vite build",
    "check:worker-types": "wrangler types --check && node scripts/strip-worker-types.mjs",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "dev": "pnpm dev:app",
    "dev:app": "PORTLESS_TLD=dev portless",
    "dev:vite": "vite dev --port ${PORT:-3000}",
    "preview": "vite preview",
    "db:migrate": "wrangler d1 migrations apply ai-tutor-sessions --local",
    "db:migrate:remote": "wrangler d1 migrations apply ai-tutor-sessions --remote",
    "types": "wrangler types && node scripts/strip-worker-types.mjs",
    "typecheck:tsc": "pnpm check:worker-types && tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.worker.json",
    "typecheck": "pnpm typecheck:tsc && pnpm test",
    "test": "vitest run"
  },
  "portless": {
    "name": "ai-tutor",
    "script": "dev:vite"
  },
  "dependencies": {
    "@tanstack/ai": "^0.33.0",
    "@tanstack/ai-openai": "^0.15.3",
    "@tanstack/ai-openrouter": "^0.14.1",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-form-start": "^1.33.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-pacer": "^0.22.1",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.16",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.26",
    "aws4fetch": "1.0.20",
    "better-auth": "1.6.20",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "1.42.1",
    "@cloudflare/workers-types": "4.20260621.1",
    "@tanstack/react-devtools": "^0.10.7",
    "@types/node": "24.13.2",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.2",
    "portless": "0.14.0",
    "typescript": "6.0.3",
    "vite": "8.0.16",
    "vitest": "4.1.9",
    "wrangler": "4.103.0"
  }
}
