{
  "name": "ai-tutor",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.6.0",
  "engines": {
    "node": ">=24 <25",
    "pnpm": ">=11 <12"
  },
  "scripts": {
    "build": "pnpm build:client && pnpm check:worker-types && tsc -p tsconfig.server.json && tsc -p tsconfig.worker.json",
    "build:client": "tsc -p tsconfig.client.json --noEmit && esbuild src/client/main.tsx --bundle --format=esm --platform=browser --jsx=automatic --loader:.tsx=tsx --sourcemap --outfile=public/client.js",
    "check:worker-types": "wrangler types --check",
    "deploy": "pnpm build && wrangler deploy",
    "deploy:dry-run": "pnpm build && wrangler deploy --dry-run",
    "dev": "node scripts/dev.mjs",
    "dev:app": "pnpm build && node dist/server.js",
    "dev:worker": "pnpm build:client && wrangler dev",
    "start": "node scripts/dev.mjs --script start:app",
    "start:app": "pnpm build && node dist/server.js",
    "typecheck": "pnpm check:worker-types && tsc -p tsconfig.server.json --noEmit && tsc -p tsconfig.client.json --noEmit && tsc -p tsconfig.worker.json && pnpm test",
    "test": "node --experimental-strip-types --test test/**/*.test.ts"
  },
  "portless": {
    "name": "ai-tutor",
    "script": "dev:app"
  },
  "dependencies": {
    "@openai/agents": "^0.11.6",
    "dotenv": "^17.2.3",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260613.1",
    "@types/node": "^24.10.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "esbuild": "^0.28.1",
    "portless": "^0.14.0",
    "typescript": "^5.9.3",
    "wrangler": "^4.100.0"
  }
}
