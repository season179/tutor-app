# Used by `wrangler dev` (local development). Copy to `.dev.vars`.
#
# `pnpm dev` runs the app behind Portless at https://ai-tutor.dev, proxying to
# the wrangler dev server on a port Portless auto-assigns (no fixed 8787).
# The .dev TLD is required because Google OAuth rejects *.localhost redirect URIs.
#
# The TLD belongs to the running Portless proxy (one shared daemon for all apps);
# whichever app starts it first sets the TLD. Persist it globally so a stray
# `pnpm dev` can't revert it to .localhost. One-time setup:
#   1. echo 'export PORTLESS_TLD=dev' >> ~/.zshenv     # persist .dev for every proxy start
#   2. pnpm portless proxy stop && pnpm dev            # restart proxy so .dev takes effect
#   3. pnpm portless trust && pnpm portless hosts sync # trust local CA + map ai-tutor.dev -> 127.0.0.1

OPENROUTER_API_KEY=your-openrouter-api-key

# better-auth (generate a secret: `openssl rand -base64 32`)
BETTER_AUTH_SECRET=your-better-auth-secret
# Public base URL of the app. Local dev runs behind Portless at:
BETTER_AUTH_URL=https://ai-tutor.dev

# Google OAuth. Create a project at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI for local dev: https://ai-tutor.dev/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Voice / model defaults (optional — fall back to wrangler.jsonc vars).
# STT/TTS run on OpenRouter; the tutor/gate/verifier/vision model vars are vestigial here
# (reasoning lives in Worker B — see reasoning-worker/.dev.vars), kept for back-compat.
OPENAI_TUTOR_MODEL=gpt-5.5
OPENAI_VERIFIER_MODEL=gpt-5.5
OPENROUTER_TRANSCRIBE_MODEL=qwen/qwen3-asr-flash-2026-02-10
OPENROUTER_TTS_MODEL=google/gemini-3.1-flash-tts-preview
OPENROUTER_TTS_VOICE=Aoede
OPENAI_VISION_MODEL=gpt-5.5

# R2 direct-upload credentials (Cloudflare dashboard → R2 → Manage API tokens)
R2_ACCESS_KEY_ID=your-r2-access-key-id
R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
R2_ACCOUNT_ID=your-cloudflare-account-id
