# Used by `wrangler dev` (local development). Copy to `.dev.vars`.
#
# `pnpm dev` runs the app behind Portless at https://ai-tutor.dev (proxying to
# the wrangler dev server on port 8787). One-time setup:
#   1. pnpm portless proxy start --tld dev     # sets + persists the .dev TLD
#   2. pnpm portless trust                      # trust the local CA (HTTPS)
# The .dev TLD is shared across all Portless apps and persists across restarts.

OPENAI_API_KEY=your-openai-api-key

# better-auth (generate a secret: `openssl rand -base64 32`)
BETTER_AUTH_SECRET=your-better-auth-secret
# Public base URL of the app. Local dev runs behind Portless at:
BETTER_AUTH_URL=https://ai-tutor.dev

# Google OAuth. Create a project at https://console.cloud.google.com/apis/credentials
# Authorized redirect URI for local dev: https://ai-tutor.dev/api/auth/callback/google
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret

# Voice / model defaults (optional — fall back to wrangler.jsonc vars)
VOICE_BACKEND=openai-voice-pipeline
OPENAI_TUTOR_MODEL=gpt-5.5
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=marin
OPENAI_REALTIME_MODEL=gpt-realtime-2
OPENAI_REALTIME_VOICE=marin
OPENAI_SAFETY_IDENTIFIER=local-ai-tutor-user
